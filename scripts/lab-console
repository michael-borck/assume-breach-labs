#!/usr/bin/env bash
# ---------------------------------------------------------------------------
# Assume Breach Labs — immersive console.
#
# Hides Docker entirely. The student "logs in" and drives the whole lab with
# plain-English commands. The REAL security tools still run underneath, shown
# behind a simulated host prompt (e.g. "[pc2] $ ping 10.1.1.2"), so students
# learn ping / iptables / dig by seeing them — they just never touch `docker`.
#
# Launched by ./start.sh. Module defaults to 07 (Firewalls).
# ---------------------------------------------------------------------------
set -uo pipefail

MODULE="${LAB_MODULE:-07}"
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOGFILE="$(mktemp -t lab-console.XXXXXX)"

C_TITLE='\033[1;36m'; C_OK='\033[0;32m'; C_WARN='\033[1;33m'
C_ERR='\033[0;31m'; C_DIM='\033[0;90m'; C_PROMPT='\033[1;35m'; NC='\033[0m'

# --- host table (Module 07) ------------------------------------------------
host_ip() {
    case "$1" in
        pc1) echo 10.1.1.2 ;;  pc2) echo 10.1.2.3 ;;
        pc3) echo 10.1.2.4 ;;  pc4) echo 10.1.2.5 ;;
        dns) echo 10.1.1.253 ;; firewall|fw) echo 10.1.1.254 ;;
        *) echo "" ;;
    esac
}
HOSTS="pc1 pc2 pc3 pc4 firewall dns"

banner() {
    printf "${C_TITLE}"
    cat <<'EOF'

  +===================================================================+
  |                                                                   |
  |        A S S U M E   B R E A C H   —   S E C U R I T Y   L A B     |
  |                                                                   |
  |             Network Security Workstation  ·  Module 07            |
  |                        Firewalls & Filtering                      |
  |                                                                   |
  +===================================================================+
EOF
    printf "${NC}\n"
}

need_docker() {
    if ! command -v docker >/dev/null 2>&1; then
        printf "${C_ERR}Docker is not installed.${NC}\n"
        printf "Install Docker Desktop: https://www.docker.com/products/docker-desktop\n"
        exit 1
    fi
    if ! docker info >/dev/null 2>&1; then
        printf "${C_ERR}Docker is not running.${NC} Start Docker Desktop and try again.\n"
        exit 1
    fi
}

lab_is_up() { [ -n "$(docker ps -q --filter name=m07-firewall 2>/dev/null)" ]; }

bring_up() {
    if lab_is_up; then
        printf "${C_OK}Lab already running.${NC}\n"; return
    fi
    printf "${C_DIM}Connecting to the lab network...${NC}\n"; sleep 1
    printf "${C_DIM}Powering on workstations and firewall...${NC}\n"
    # Build the shared image ONCE (all module-07 services share one image tag;
    # building per-service in parallel races on the legacy builder), then start.
    (
        cd "$PROJECT_ROOT"
        docker compose --profile "module-${MODULE}" build m07-firewall \
            && docker compose --profile "module-${MODULE}" up -d
    ) >"$LOGFILE" 2>&1 &
    local pid=$!
    while kill -0 "$pid" 2>/dev/null; do printf "."; sleep 1; done
    printf "\n"
    if ! wait "$pid" || ! lab_is_up; then
        printf "${C_ERR}Could not start the lab. Details:${NC}\n"
        tail -n 15 "$LOGFILE"; exit 1
    fi
    printf "${C_OK}Connection established. You are logged in.${NC}\n"
}

topology() {
    cat <<'EOF'

        INSIDE  (protected)              OUTSIDE  (other staff)
     +------------------------+       +--------------------------+
     |  pc1   10.1.1.2        |  FW   |  pc2   10.1.2.3          |
     |  dns   10.1.1.253      | ----- |  pc3   10.1.2.4          |
     |                        |       |  pc4   10.1.2.5          |
     +------------------------+       +--------------------------+
        The firewall (FW) routes and filters traffic between the two sides.
EOF
}

show_help() {
    cat <<EOF

  Commands (type them at the lab> prompt):
    ${C_PROMPT}ping <from> <to>${NC}     e.g.  ping pc2 pc1     — ping one host from another
    ${C_PROMPT}connect <host>${NC}       e.g.  connect pc2      — open a shell ON that host
    ${C_PROMPT}rules load${NC}                              — apply the teaching firewall rules
    ${C_PROMPT}rules show${NC}                              — list the current firewall rules
    ${C_PROMPT}rules clear${NC}                             — remove all firewall rules
    ${C_PROMPT}dns <name>${NC}          e.g.  dns coke.dreamland.com.au  — look up a name
    ${C_PROMPT}map${NC}                                     — show the network diagram
    ${C_PROMPT}hosts${NC}                                   — list the machines
    ${C_PROMPT}guide${NC}                                   — where to find the lab guide
    ${C_PROMPT}help${NC}                                    — this list
    ${C_PROMPT}quit${NC}                                    — leave the lab
EOF
    printf "\n"
}

# Run a real command on a host, shown behind a simulated host prompt (no docker visible)
on_host() {
    local host="$1"; shift
    printf "${C_DIM}[%s] \$ %s${NC}\n" "$host" "$*"
    docker exec "m07-${host}" "$@" 2>&1 || true
}

do_ping() {
    local from="$1" to="${2:-}"
    local ip; ip="$(host_ip "${to}")"
    if [ -z "${to}" ] || [ -z "$ip" ]; then printf "${C_ERR}usage: ping <from> <to>   (hosts: %s)${NC}\n" "$HOSTS"; return; fi
    if [ -z "$(host_ip "$from")" ]; then printf "${C_ERR}unknown host: %s${NC}\n" "$from"; return; fi
    on_host "$from" ping -c3 -W2 "$ip"
}

do_rules() {
    case "${1:-show}" in
        load|reset) on_host firewall /rules/rules.sh ;;
        show)       on_host firewall iptables -L FORWARD -n -v --line-numbers ;;
        clear)      on_host firewall iptables -F FORWARD; printf "${C_OK}Firewall rules cleared (all traffic now allowed).${NC}\n" ;;
        *)          printf "${C_ERR}usage: rules load|show|clear${NC}\n" ;;
    esac
}

do_connect() {
    local host="${1:-}"
    if [ -z "$(host_ip "$host")" ]; then printf "${C_ERR}unknown host: %s (try: %s)${NC}\n" "$host" "$HOSTS"; return; fi
    printf "${C_DIM}Opening a session on %s. Type 'exit' to return to the lab console.${NC}\n" "$host"
    docker exec -it -e "PS1=[$host] \$ " "m07-${host}" bash --norc 2>/dev/null \
        || docker exec -it "m07-${host}" sh
}

do_dns() {
    local name="${1:-}"
    [ -n "$name" ] || { printf "${C_ERR}usage: dns <name>${NC}\n"; return; }
    on_host pc1 getent hosts "$name"
}

teardown_prompt() {
    printf "\n"
    read -r -p "Shut down the lab machines before leaving? (y/N) " ans
    case "$ans" in
        [Yy]*) ( cd "$PROJECT_ROOT" && docker compose stop ) >"$LOGFILE" 2>&1
               printf "${C_OK}Lab stopped. Run ./start.sh to come back.${NC}\n" ;;
        *)     printf "${C_DIM}Lab left running. ./start.sh to return, or 'make stop' to halt it.${NC}\n" ;;
    esac
}

repl() {
    printf "\n${C_OK}Welcome%s.${NC} You are at the network security console.\n" \
        "${ANALYST:+, $ANALYST}"
    topology
    printf "\nType ${C_PROMPT}help${NC} for commands, or start with:  ${C_PROMPT}rules show${NC}\n\n"
    while true; do
        printf "${C_PROMPT}lab>${NC} "
        if ! read -r line; then break; fi
        # shellcheck disable=SC2086
        set -- $line
        cmd="${1:-}"; [ $# -gt 0 ] && shift || true
        case "$cmd" in
            "")        : ;;
            ping)      do_ping "${1:-}" "${2:-}" ;;
            connect|ssh) do_connect "${1:-}" ;;
            rules)     do_rules "${1:-show}" ;;
            dns)       do_dns "${1:-}" ;;
            map)       topology ;;
            hosts)     printf "  %s\n" "$HOSTS" ;;
            guide)     printf "  modules/module-07-firewalls/LAB-GUIDE.md\n" ;;
            help|\?)   show_help ;;
            quit|exit|logout) break ;;
            *)         printf "${C_ERR}unknown command: %s${NC}  (type 'help')\n" "$cmd" ;;
        esac
    done
    teardown_prompt
}

# --- main ------------------------------------------------------------------
ANALYST="${1:-}"
banner
need_docker
if [ -z "$ANALYST" ] && [ -t 0 ]; then
    read -r -p "Enter your name (for the lab session): " ANALYST
fi
bring_up
repl
