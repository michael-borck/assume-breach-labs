{
  "name": "assume-breach-labs",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "docker --version",
  "forwardPorts": [8055, 3006, 8090, 8443, 8444, 8445],
  "portsAttributes": {
    "8055": { "label": "Module 5 — Risk calculator", "onAutoForward": "silent" },
    "3006": { "label": "Module 6 — Wireshark", "onAutoForward": "silent" },
    "8090": { "label": "Module 9 — Awareness quiz", "onAutoForward": "silent" },
    "8443": { "label": "Module 9 — Broken cert (expired)", "onAutoForward": "silent" },
    "8444": { "label": "Module 9 — Broken cert (self-signed)", "onAutoForward": "silent" },
    "8445": { "label": "Module 9 — Broken cert (wrong host)", "onAutoForward": "silent" }
  }
}
