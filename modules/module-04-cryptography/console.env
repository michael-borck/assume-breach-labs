# Module 04 console descriptor — sourced by scripts/lab-console.
MODULE_NO=04
MODULE_TITLE="Cryptography"
MODULE_SUBTITLE="Cryptography Workstation"
UP_CHECK="m04-station"
HOSTS="station"

host_ip() { case "$1" in station) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  station  — your cryptography workstation             |
     |                                                       |
     |  Classic ciphers:  cipher (Caesar, Atbash)            |
     |  Public-key:       gpg  (real PGP: keys, encrypt,     |
     |                          decrypt, sign, verify)       |
     |  challenge.txt  — an intercepted message to break     |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Part A — classic ciphers:
    ${C_PROMPT}challenge${NC}             show the intercepted ciphertext
    ${C_PROMPT}caesar break <text>${NC}   try all 25 Caesar shifts (crack it)
    ${C_PROMPT}caesar shift <n> <text>${NC}  shift text by n
    ${C_PROMPT}atbash <text>${NC}         apply the Atbash cipher

  Part B — public-key (PGP) with two people, Alice and Bob:
    ${C_PROMPT}keygen${NC}                create Alice's and Bob's key pairs
    ${C_PROMPT}keys${NC}                  list the keys in the keyring
    ${C_PROMPT}encrypt bob <message>${NC} encrypt a message so only Bob can read it
    ${C_PROMPT}decrypt${NC}               decrypt the message (with Bob's private key)
    ${C_PROMPT}sign <message>${NC}        Alice signs a message
    ${C_PROMPT}verify${NC}                check the signature
    ${C_PROMPT}tamper${NC}                alter the encrypted message, then try to decrypt
    ${C_PROMPT}connect station${NC}       drop into the shell to run gpg yourself
EOF
}

_gpg() { on_host station sh -c "$1"; }   # run a shell one-liner on the station

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        challenge) on_host station cat challenge.txt ;;
        caesar)
            local sub="${1:-}"; shift 2>/dev/null || true
            case "$sub" in
                break) on_host station cipher break "$*" ;;
                shift) local n="${1:-0}"; shift 2>/dev/null || true; on_host station cipher shift "$n" "$*" ;;
                *) printf "${C_ERR}usage: caesar break <text> | caesar shift <n> <text>${NC}\n" ;;
            esac ;;
        atbash) on_host station cipher atbash "$*" ;;
        keygen) on_host station sh make-keys.sh ;;
        keys)   on_host station gpg --list-keys ;;
        encrypt)
            local to="${1:-}"; shift 2>/dev/null || true
            case "$to" in alice|bob) : ;; *) printf "${C_ERR}usage: encrypt bob <message>  (recipient: alice or bob)${NC}\n"; return 0 ;; esac
            [ -n "$*" ] || { printf "${C_ERR}usage: encrypt %s <message>${NC}\n" "$to"; return 0; }
            _gpg "printf '%s' \"$*\" | gpg --yes --armor --trust-model always -r ${to}@lab -e -o message.asc && echo '--- message.asc (send this) ---' && cat message.asc" ;;
        decrypt) _gpg "gpg --yes -d message.asc" ;;
        sign)
            [ -n "$*" ] || { printf "${C_ERR}usage: sign <message>${NC}\n"; return 0; }
            _gpg "printf '%s' \"$*\" | gpg --yes --clearsign -u alice@lab -o signed.asc && echo '--- signed.asc ---' && cat signed.asc" ;;
        verify) _gpg "gpg --verify signed.asc" ;;
        tamper)
            _gpg "if [ ! -f message.asc ]; then echo 'Encrypt something first (encrypt bob <message>).'; else sed -i '3s/./X/' message.asc; echo '(flipped one character in the ciphertext, then trying to decrypt:)'; gpg --yes -d message.asc; fi" ;;
        *) return 1 ;;
    esac
}
