# Module 04 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: this module's whole point is using real cryptography tools — a
# classic-cipher tool and real GnuPG (PGP) — so we don't wrap it in a lab>
# prompt with invented verbs. Setting SHELL_HOST makes lab-console log the
# student straight into the workstation container as a real interactive shell
# (analyst on 'station'), where they run the actual commands — cipher, gpg.
# The welcome banner, themed prompt and `labhelp` command live in the station
# image (modules/module-04-cryptography/station/).
MODULE_NO=04
MODULE_TITLE="Cryptography"
MODULE_SUBTITLE="Cryptography Workstation"
UP_CHECK="m04-station"
HOSTS="station"
SHELL_HOST="station"
