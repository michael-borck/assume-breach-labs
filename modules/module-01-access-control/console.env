# Module 01 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: this module's whole point is learning real Linux users, groups,
# permissions and ACLs, so we don't wrap it in a lab> prompt with invented verbs.
# Setting SHELL_HOST makes lab-console log the student straight into the
# workstation container as a real interactive shell (root on 'station'), where
# they run the actual commands — ls, chmod, chown, usermod, setfacl, getfacl.
# The welcome banner, themed prompt and `labhelp` command live in the station
# image (modules/module-01-access-control/station/).
MODULE_NO=01
MODULE_TITLE="Access Control & Isolation"
MODULE_SUBTITLE="Security Workstation"
UP_CHECK="m01-station"
HOSTS="station"
SHELL_HOST="station"
