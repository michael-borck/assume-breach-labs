# Module 01 console descriptor — sourced by scripts/lab-console.
MODULE_NO=01
MODULE_TITLE="Access Control & Isolation"
MODULE_SUBTITLE="Systems Administration Console"
UP_CHECK="m01-station"
HOSTS="station"

host_ip() { case "$1" in station) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  You are the administrator (root) of an office server.|
     |                                                       |
     |  Staff accounts:  rico    jane    carlos              |
     |  Group:           hr  (empty — you fill it)           |
     |  Files in /office:                                    |
     |     salaries.csv   confidential (HR only)             |
     |     notice.txt     public                             |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Module 01 commands:
    ${C_PROMPT}files${NC}                     list the office files and their permissions
    ${C_PROMPT}read <user> <file>${NC}        try to read a file AS that user (e.g. read rico salaries.csv)
    ${C_PROMPT}perms <file>${NC}              show full permissions + any ACLs on a file
    ${C_PROMPT}chmod <mode> <file>${NC}       change permissions (e.g. chmod 640 salaries.csv)
    ${C_PROMPT}chown <owner[:group]> <file>${NC}  change owner/group (e.g. chown root:hr salaries.csv)
    ${C_PROMPT}addgroup <user> <group>${NC}   add a user to a group (e.g. addgroup jane hr)
    ${C_PROMPT}grant <user> <file>${NC}       give ONE user read access via an ACL
    ${C_PROMPT}revoke <user> <file>${NC}      remove that user's ACL
    ${C_PROMPT}connect station${NC}           drop into the admin shell
EOF
}

_f() { printf '/office/%s' "$1"; }   # resolve a bare filename to its path

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        files) on_host station ls -l /office ;;
        read)
            local u="${1:-}" f="${2:-}"
            [ -n "$u" ] && [ -n "$f" ] || { printf "${C_ERR}usage: read <user> <file>${NC}\n"; return 0; }
            printf "${C_DIM}[as %s] \$ cat /office/%s${NC}\n" "$u" "$f"
            docker exec "$(host_container station)" runuser -u "$u" -- cat "$(_f "$f")" 2>&1 || true ;;
        perms)
            local f="${1:-}"; [ -n "$f" ] || { printf "${C_ERR}usage: perms <file>${NC}\n"; return 0; }
            on_host station ls -l "$(_f "$f")"
            on_host station getfacl -p "$(_f "$f")" ;;
        chmod)
            local m="${1:-}" f="${2:-}"; [ -n "$m" ] && [ -n "$f" ] || { printf "${C_ERR}usage: chmod <mode> <file>${NC}\n"; return 0; }
            on_host station chmod "$m" "$(_f "$f")"; on_host station ls -l "$(_f "$f")" ;;
        chown)
            local o="${1:-}" f="${2:-}"; [ -n "$o" ] && [ -n "$f" ] || { printf "${C_ERR}usage: chown <owner[:group]> <file>${NC}\n"; return 0; }
            on_host station chown "$o" "$(_f "$f")"; on_host station ls -l "$(_f "$f")" ;;
        addgroup)
            local u="${1:-}" g="${2:-}"; [ -n "$u" ] && [ -n "$g" ] || { printf "${C_ERR}usage: addgroup <user> <group>${NC}\n"; return 0; }
            on_host station usermod -aG "$g" "$u"; on_host station sh -c "id $u" ;;
        grant)
            local u="${1:-}" f="${2:-}"; [ -n "$u" ] && [ -n "$f" ] || { printf "${C_ERR}usage: grant <user> <file>${NC}\n"; return 0; }
            on_host station setfacl -m "u:$u:r" "$(_f "$f")"; on_host station getfacl -p "$(_f "$f")" ;;
        revoke)
            local u="${1:-}" f="${2:-}"; [ -n "$u" ] && [ -n "$f" ] || { printf "${C_ERR}usage: revoke <user> <file>${NC}\n"; return 0; }
            on_host station setfacl -x "u:$u" "$(_f "$f")"; on_host station getfacl -p "$(_f "$f")" ;;
        *) return 1 ;;
    esac
}
