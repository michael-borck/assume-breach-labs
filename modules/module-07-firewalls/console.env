# Module 07 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: a multi-host firewall lab done on real machines. The student logs
# into the FIREWALL (the box they administer) as a real root shell, edits the
# real iptables FORWARD ruleset there, and uses real `ssh` to hop to the
# workstations (ssh pc2; ping pc1) to test what the firewall lets through — no
# lab> verbs. ssh from the firewall to a directly-connected pc is NOT forwarded,
# so management access is never cut off by the FORWARD rules, just like a real
# firewall. The banner, `labhelp` and `netmap` live in the node image
# (modules/module-07-firewalls/node/).
MODULE_NO=07
MODULE_TITLE="Firewalls & Filtering"
MODULE_SUBTITLE="Network Security Workstation"
UP_CHECK="m07-firewall"
HOSTS="pc1 pc2 pc3 pc4 firewall dns"
SHELL_HOST="firewall"
