# Module 07 console descriptor — sourced by scripts/lab-console.
MODULE_NO=07
MODULE_TITLE="Firewalls & Filtering"
MODULE_SUBTITLE="Network Security Workstation"
UP_CHECK="m07-firewall"
HOSTS="pc1 pc2 pc3 pc4 firewall dns"

host_ip() {
    case "$1" in
        pc1) echo 10.1.1.2 ;;  pc2) echo 10.1.2.3 ;;
        pc3) echo 10.1.2.4 ;;  pc4) echo 10.1.2.5 ;;
        dns) echo 10.1.1.253 ;; firewall|fw) echo 10.1.1.254 ;;
        *) echo "" ;;
    esac
}

topology() {
    cat <<'EOF'

        INSIDE  (protected)              OUTSIDE  (other staff)
     +------------------------+       +--------------------------+
     |  pc1   10.1.1.2        |  FW   |  pc2   10.1.2.3          |
     |  dns   10.1.1.253      | ----- |  pc3   10.1.2.4          |
     |                        |       |  pc4   10.1.2.5          |
     +------------------------+       +--------------------------+
        The firewall routes and filters traffic between the two sides.
EOF
}

module_help() {
    cat <<EOF

  Module 07 commands:
    ${C_PROMPT}ping <from> <to>${NC}   ping one machine from another, e.g. ping pc2 pc1
    ${C_PROMPT}rules show${NC}         list the firewall's current rules
    ${C_PROMPT}rules load${NC}         apply this lab's teaching ruleset
    ${C_PROMPT}rules clear${NC}        remove all rules (allow everything)
    ${C_PROMPT}dns <name>${NC}         look up a name, e.g. dns coke.dreamland.com.au
EOF
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        ping)
            local from="${1:-}" to="${2:-}" ip
            ip="$(host_ip "$to")"
            if [ -z "$to" ] || [ -z "$ip" ]; then printf "${C_ERR}usage: ping <from> <to>  (hosts: %s)${NC}\n" "$HOSTS"; return 0; fi
            if [ -z "$(host_ip "$from")" ]; then printf "${C_ERR}unknown host: %s${NC}\n" "$from"; return 0; fi
            on_host "$from" ping -c3 -W2 "$ip" ;;
        rules)
            case "${1:-show}" in
                load|reset) on_host firewall /rules/rules.sh ;;
                show)       on_host firewall iptables -L FORWARD -n -v --line-numbers ;;
                clear)      on_host firewall iptables -F FORWARD; printf "${C_OK}Firewall rules cleared.${NC}\n" ;;
                *)          printf "${C_ERR}usage: rules load|show|clear${NC}\n" ;;
            esac ;;
        dns)
            [ -n "${1:-}" ] || { printf "${C_ERR}usage: dns <name>${NC}\n"; return 0; }
            on_host pc1 getent hosts "$1" ;;
        *) return 1 ;;
    esac
}
