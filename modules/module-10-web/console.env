# Module 10 console descriptor — a browser-based web-security module.
MODULE_NO=10
MODULE_TITLE="Web Security"
MODULE_SUBTITLE="Broken Web App Lab"
UP_CHECK="m10-web"
HOSTS="webapp"
BROWSER_URL="http://localhost:3010"

host_ip() { case "$1" in webapp) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  This lab runs in your web browser.                   |
     |                                                       |
     |  A deliberately vulnerable shop (OWASP Juice Shop)    |
     |  at  http://localhost:3010                            |
     |                                                       |
     |  It is built to be broken, so attacking it HERE is    |
     |  legal and safe. Never do this to a site you do not   |
     |  own or have permission to test.                      |
     |                                                       |
     |  (Give it ~20 seconds to start the first time.)       |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Module 10 commands:
    ${C_PROMPT}open${NC}                  open the vulnerable web app in your browser
    ${C_PROMPT}url${NC}                   show the address to visit
EOF
}

# No in-container commands — the whole lab is the browser page.
module_dispatch() { return 1; }
