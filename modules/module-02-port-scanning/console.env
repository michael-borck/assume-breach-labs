# Module 02 console descriptor — sourced by scripts/lab-console.
MODULE_NO=02
MODULE_TITLE="Port Scanning & Enumeration"
MODULE_SUBTITLE="Penetration Testing Workstation"
UP_CHECK="m02-attacker"
HOSTS="web files app attacker"
SUBNET="10.2.0.0/24"

host_ip() {
    case "$1" in
        web) echo 10.2.0.20 ;;  files) echo 10.2.0.30 ;;
        app) echo 10.2.0.40 ;;  attacker) echo 10.2.0.10 ;;
        *) echo "" ;;
    esac
}

topology() {
    cat <<'EOF'

     attacker 10.2.0.10  ─── the network 10.2.0.0/24 ───┐
       (you, with nmap)                                  │
                                +------------------------+------------------+
                                |  web    10.2.0.20   HTTP :80              |
                                |  files  10.2.0.30   SSH :22, FTP :21      |
                                |  app    10.2.0.40   HTTP :8080, ? :9000   |
                                +-------------------------------------------+
        You don't know the ports yet — that's what scanning is for.
EOF
}

module_help() {
    cat <<EOF

  Module 02 commands (all run from your attacker workstation):
    ${C_PROMPT}discover${NC}            find which machines are alive on the network
    ${C_PROMPT}scan <host>${NC}         quick scan of a host's common ports (e.g. scan web)
    ${C_PROMPT}ports <host>${NC}        fuller scan (top 1000 ports)
    ${C_PROMPT}version <host>${NC}      identify the service + version on each open port (-sV)
    ${C_PROMPT}intense <host>${NC}      aggressive scan: version, OS guess, scripts (-A)
    ${C_PROMPT}connect attacker${NC}    drop into the workstation shell to run nmap yourself
EOF
}

# Resolve a friendly host name to an IP; empty if unknown. Also accept a raw IP.
_target_ip() {
    local ip; ip="$(host_ip "$1")"
    [ -n "$ip" ] && { echo "$ip"; return; }
    case "$1" in *.*.*.*) echo "$1" ;; *) echo "" ;; esac
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        discover)
            on_host attacker nmap -sn "$SUBNET" ;;
        scan|ports|version|intense)
            local ip; ip="$(_target_ip "${1:-}")"
            if [ -z "$ip" ]; then printf "${C_ERR}usage: %s <host>  (hosts: %s)${NC}\n" "$cmd" "$HOSTS"; return 0; fi
            case "$cmd" in
                scan)    on_host attacker nmap -F "$ip" ;;
                ports)   on_host attacker nmap "$ip" ;;
                version) on_host attacker nmap -sV "$ip" ;;
                intense) on_host attacker nmap -A -T4 "$ip" ;;
            esac ;;
        *) return 1 ;;
    esac
}
