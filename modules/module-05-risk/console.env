# Module 05 console descriptor — a browser-based module.
MODULE_NO=05
MODULE_TITLE="Risk Management"
MODULE_SUBTITLE="Risk & Assurance Desk"
UP_CHECK="m05-web"
HOSTS="calculator"
BROWSER_URL="http://localhost:8055"

host_ip() { case "$1" in calculator) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  This lab runs in your web browser.                   |
     |                                                       |
     |  An interactive risk calculator for XYZ Software      |
     |  Company: enter each threat's loss, frequency and     |
     |  control cost, and see which safeguards pay for        |
     |  themselves (SLE x ARO = ALE, then cost-benefit).     |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Module 05 commands:
    ${C_PROMPT}open${NC}                  open the risk calculator in your browser
    ${C_PROMPT}url${NC}                   show the address to visit
EOF
}

# No in-container commands — the whole lab is the browser page.
module_dispatch() { return 1; }
