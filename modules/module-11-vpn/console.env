# Module 11 console descriptor — VPN / tunnelling.
MODULE_NO=11
MODULE_TITLE="VPN & Tunnelling"
MODULE_SUBTITLE="Secure Communications Lab"
UP_CHECK="m11-eavesdropper"
HOSTS="client server eavesdropper"

host_ip() {
    case "$1" in
        client) echo 10.11.0.10 ;; server) echo 10.11.1.20 ;;
        eavesdropper) echo 10.11.0.254 ;; *) echo "" ;;
    esac
}

topology() {
    cat <<'EOF'

     client 10.11.0.10 ──┐                        ┌── server 10.11.1.20
       (office network)  │   EAVESDROPPER (on-path) │   (datacentre, login service)
                         └──  10.11.0.254 / .254  ──┘
        All traffic between client and server crosses the eavesdropper — like
        your data crossing the internet through networks you don't control.
EOF
}

module_help() {
    cat <<EOF

  Module 11 commands:
    ${C_PROMPT}eavesdrop${NC}             the client logs in while the eavesdropper watches the wire
    ${C_PROMPT}vpn on${NC}                bring up the WireGuard tunnel (client + server)
    ${C_PROMPT}vpn off${NC}               tear the tunnel down
    ${C_PROMPT}status${NC}                is the VPN up? show the tunnel state
    ${C_PROMPT}connect <host>${NC}        shell on a machine (client, server, eavesdropper)
EOF
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        eavesdrop)
            printf "${C_DIM}The eavesdropper sits on the wire between client and server.${NC}\n"
            printf "${C_DIM}Sniffing while the client sends its login...${NC}\n\n"
            docker exec -d m11-eavesdropper sh -c 'timeout 7 tcpdump -A -nn -i any "tcp port 8080 or udp port 51820" > /tmp/sniff.txt 2>/dev/null'
            sleep 1
            docker exec m11-client /send-login.sh
            sleep 6
            printf "\n${C_DIM}[eavesdropper] \$ tcpdump -A -i any  (what crossed the wire)${NC}\n"
            if docker exec m11-eavesdropper grep -qa "password=" /tmp/sniff.txt 2>/dev/null; then
                printf "${C_ERR}  ⚠  CAPTURED IN THE CLEAR:${NC}\n"
                docker exec m11-eavesdropper sh -c 'grep -a "password=" /tmp/sniff.txt | head -1 | sed "s/^/     /"'
                printf "${C_ERR}  Anyone on the path just read the password. Turn the VPN on and try again.${NC}\n"
            else
                local n
                n=$(docker exec m11-eavesdropper sh -c 'grep -ac "51820" /tmp/sniff.txt' 2>/dev/null)
                printf "${C_OK}  ✓  Only encrypted WireGuard traffic seen (~%s packets on UDP 51820).${NC}\n" "${n:-0}"
                printf "${C_OK}  The login is inside the tunnel — the password is invisible on the wire.${NC}\n"
            fi ;;
        vpn)
            case "${1:-}" in
                on)
                    printf "${C_DIM}Bringing up the WireGuard tunnel...${NC}\n"
                    docker exec m11-server wg-quick up wg0 >/dev/null 2>&1
                    docker exec m11-client wg-quick up wg0 >/dev/null 2>&1
                    sleep 1
                    docker exec m11-client sh -c 'wg show wg0 | grep -q "latest handshake" && echo up' >/dev/null 2>&1 \
                        && printf "${C_OK}Tunnel up. client 10.99.0.2 <-> server 10.99.0.1 (encrypted).${NC}\n" \
                        || printf "${C_OK}Tunnel started. Run 'eavesdrop' to see the difference.${NC}\n" ;;
                off)
                    docker exec m11-client wg-quick down wg0 >/dev/null 2>&1
                    docker exec m11-server wg-quick down wg0 >/dev/null 2>&1
                    printf "${C_OK}Tunnel down. Traffic is back in the clear.${NC}\n" ;;
                *) printf "${C_ERR}usage: vpn on | vpn off${NC}\n" ;;
            esac ;;
        status)
            if docker exec m11-client ip link show wg0 >/dev/null 2>&1; then
                printf "${C_OK}VPN is ON:${NC}\n"
                docker exec m11-client wg show wg0 2>/dev/null | sed 's/^/  /'
            else
                printf "${C_DIM}VPN is OFF — traffic crosses the eavesdropper in the clear.${NC}\n"
            fi ;;
        *) return 1 ;;
    esac
}
