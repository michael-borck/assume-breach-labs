# Module 11 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: the student logs into the CLIENT (real root shell) and does the
# real thing — curl a login to the server, ssh to the eavesdropper to read it
# off the wire, then bring up a real WireGuard tunnel (wg-quick up wg0) on the
# client and server and watch the eavesdropper go dark. No lab> verbs; the
# eavesdropper runs a real tcpdump capture the student reads. The banner,
# `labhelp` and `netmap` live in the node image (modules/module-11-vpn/node/).
MODULE_NO=11
MODULE_TITLE="VPN & Tunnelling"
MODULE_SUBTITLE="Secure Communications Lab"
UP_CHECK="m11-eavesdropper"
HOSTS="client server eavesdropper"
SHELL_HOST="client"
