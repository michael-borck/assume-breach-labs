# Module 06 console descriptor — Wireshark in the browser.
MODULE_NO=06
MODULE_TITLE="Packet Capture & Analysis"
MODULE_SUBTITLE="Network Analysis Workstation"
UP_CHECK="m06-wireshark"
HOSTS="wireshark"
BROWSER_URL="http://localhost:3006"

host_ip() { case "$1" in wireshark) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  Wireshark runs in your web browser.                  |
     |                                                       |
     |  Capture files to analyse live in  /pcaps :           |
     |    ftp-login      telnet-login    http-browse         |
     |    dns-query      icmp-ping       port-scan           |
     |                                                       |
     |  In Wireshark:  File > Open > /pcaps                   |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Module 06 commands:
    ${C_PROMPT}open${NC}                  open Wireshark in your browser
    ${C_PROMPT}list${NC}                  list the capture files available in /pcaps
    ${C_PROMPT}fetch${NC}                 download extra real-world sample captures
    ${C_PROMPT}connect wireshark${NC}     drop into the workstation shell (for tshark, etc.)
EOF
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        list)
            on_host wireshark sh -c 'ls -1 /pcaps/*.pcap 2>/dev/null | sed "s#/pcaps/##"' ;;
        fetch)
            printf "${C_DIM}Power-user equivalent: docker exec m06-wireshark fetch-samples${NC}\n"
            on_host wireshark fetch-samples ;;
        *) return 1 ;;
    esac
}
