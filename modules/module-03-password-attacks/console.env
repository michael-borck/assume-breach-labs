# Module 03 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: this module's whole point is running the real cracking tools —
# John the Ripper, fcrackzip, unzip — against real hashes and a real encrypted
# archive, so we don't wrap it in a lab> prompt with invented verbs. Setting
# SHELL_HOST makes lab-console log the student straight into the workstation
# container as a real interactive shell (the 'analyst' user on 'station'), where
# they run the actual commands themselves. The welcome banner, themed prompt and
# `labhelp` command live in the station image (modules/module-03-password-attacks/station/).
MODULE_NO=03
MODULE_TITLE="Password Attacks"
MODULE_SUBTITLE="Penetration Testing Workstation"
UP_CHECK="m03-station"
HOSTS="station"
SHELL_HOST="station"
