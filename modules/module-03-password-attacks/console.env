# Module 03 console descriptor — sourced by scripts/lab-console.
MODULE_NO=03
MODULE_TITLE="Password Attacks"
MODULE_SUBTITLE="Penetration Testing Workstation"
UP_CHECK="m03-station"
HOSTS="station"

host_ip() { case "$1" in station) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  station   — your cracking workstation                |
     |                                                       |
     |  /home/analyst/lab/                                   |
     |    hashes/     easy-md5, medium-sha256, windows-ntlm  |
     |    wordlists/  common-passwords.txt                   |
     |    secret.zip  (a password-protected archive)         |
     +-------------------------------------------------------+
        Tools: john (John the Ripper), fcrackzip, identify-hash
EOF
}

module_help() {
    cat <<EOF

  Module 03 commands:
    ${C_PROMPT}hashes${NC}              show the hash files you'll attack
    ${C_PROMPT}identify <hash>${NC}     guess a hash's type by its shape
    ${C_PROMPT}crack easy${NC}          crack the MD5 hashes with a wordlist (John)
    ${C_PROMPT}crack sha${NC}           crack the SHA-256 hashes
    ${C_PROMPT}crack windows${NC}       crack the Windows NTLM hashes
    ${C_PROMPT}crackzip${NC}            dictionary-attack the password-protected zip
    ${C_PROMPT}openzip <password>${NC}  open the zip once you've cracked it
    ${C_PROMPT}connect station${NC}     drop into the workstation shell (run tools yourself)
EOF
}

# wordlist + hash paths inside the station container
_WL="wordlists/common-passwords.txt"

_crack() {  # _crack <john-format> <hashfile>
    local fmt="$1" file="$2"
    on_host station john --format="$fmt" --wordlist="$_WL" "$file"
    printf "${C_DIM}--- cracked so far ---${NC}\n"
    on_host station john --format="$fmt" --show "$file"
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        hashes)
            on_host station sh -c 'for f in hashes/*; do echo "== $f =="; cat "$f"; echo; done' ;;
        identify)
            [ -n "${1:-}" ] || { printf "${C_ERR}usage: identify <hash>${NC}\n"; return 0; }
            on_host station identify-hash "$1" ;;
        crack)
            case "${1:-}" in
                easy|md5)     _crack raw-md5    hashes/easy-md5.txt ;;
                sha|sha256)   _crack raw-sha256 hashes/medium-sha256.txt ;;
                windows|nt|ntlm) _crack NT      hashes/windows-ntlm.txt ;;
                *) printf "${C_ERR}usage: crack easy|sha|windows${NC}\n" ;;
            esac ;;
        crackzip)
            on_host station fcrackzip -D -p "$_WL" -u secret.zip ;;
        openzip)
            [ -n "${1:-}" ] || { printf "${C_ERR}usage: openzip <password>${NC}\n"; return 0; }
            on_host station unzip -o -P "$1" secret.zip
            on_host station cat flag.txt ;;
        *) return 1 ;;
    esac
}
