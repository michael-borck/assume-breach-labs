# Module 08 console descriptor — sourced by scripts/lab-console.
MODULE_NO=08
MODULE_TITLE="Digital Forensics"
MODULE_SUBTITLE="Forensic Analysis Workstation"
UP_CHECK="m08-station"
HOSTS="station"

host_ip() { case "$1" in station) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  Forensic Analysis Workstation — two investigations:  |
     |                                                       |
     |  A) Email headers   emails/  legitimate  phishing  spam
     |     -> trace where a message really came from         |
     |                                                       |
     |  B) Authorship      texts/   hamilton  madison  jay   |
     |     -> whodunnit: who wrote the 'unknown' document?   |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Part A — email forensics:
    ${C_PROMPT}emails${NC}                list the email files
    ${C_PROMPT}headers <name>${NC}        show an email's raw headers (e.g. headers phishing)
    ${C_PROMPT}trace <name>${NC}          trace origin + spot spoofing (e.g. trace phishing)

  Part B — authorship analysis:
    ${C_PROMPT}authors${NC}               list the known writing samples
    ${C_PROMPT}whodunnit${NC}             identify the author of the 'unknown' document

    ${C_PROMPT}connect station${NC}       drop into the workstation shell
EOF
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        emails) on_host station sh -c 'ls -1 emails/*.eml | sed "s#emails/##"' ;;
        headers)
            local n="${1:-}"; [ -n "$n" ] || { printf "${C_ERR}usage: headers <name>${NC}\n"; return 0; }
            on_host station sh -c "sed '/^\$/q' emails/${n}.eml" ;;
        trace)
            local n="${1:-}"; [ -n "$n" ] || { printf "${C_ERR}usage: trace <name>  (legitimate|phishing|spam)${NC}\n"; return 0; }
            on_host station mailtrace "emails/${n}.eml" ;;
        authors) on_host station sh -c 'for f in texts/*.txt; do printf "%-16s %s words\n" "$(basename "$f")" "$(wc -w < "$f")"; done' ;;
        whodunnit|stylometry|analyze) on_host station stylometry texts unknown.txt ;;
        *) return 1 ;;
    esac
}
