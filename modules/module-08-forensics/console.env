# Module 08 console descriptor — sourced by scripts/lab-console.
#
# SHELL MODE: this module is about running real forensic tools on real evidence,
# so we don't wrap it in a lab> prompt with invented verbs. Setting SHELL_HOST
# makes lab-console log the student straight into the workstation container as a
# real interactive shell (analyst on 'station', in /home/analyst/lab), where they
# run the actual tools — mailtrace on the .eml files, stylometry on the author
# texts — and can inspect the raw evidence with ordinary commands (cat, sed, wc).
# The welcome banner, themed prompt and `labhelp` command live in the station
# image (modules/module-08-forensics/station/).
MODULE_NO=08
MODULE_TITLE="Digital Forensics"
MODULE_SUBTITLE="Forensic Analysis Workstation"
UP_CHECK="m08-station"
HOSTS="station"
SHELL_HOST="station"
