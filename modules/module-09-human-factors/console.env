# Module 09 console descriptor — a browser-based module (quiz + broken-cert sites).
MODULE_NO=09
MODULE_TITLE="Human Factors"
MODULE_SUBTITLE="Security Awareness Lab"
UP_CHECK="m09-quiz"
HOSTS="quiz certs"
BROWSER_URL="http://localhost:8090"

host_ip() { case "$1" in quiz|certs) echo "-" ;; *) echo "" ;; esac; }

topology() {
    cat <<'EOF'

     +-------------------------------------------------------+
     |  This lab runs in your web browser. Two parts:        |
     |                                                       |
     |  A) Awareness quiz     http://localhost:8090          |
     |     phishing + e-safety, scored with explanations     |
     |                                                       |
     |  B) Broken-certificate sites (real browser warnings): |
     |     https://localhost:8443   expired certificate      |
     |     https://localhost:8444   self-signed / untrusted  |
     |     https://localhost:8445   wrong hostname           |
     +-------------------------------------------------------+
EOF
}

module_help() {
    cat <<EOF

  Module 09 commands:
    ${C_PROMPT}open${NC}                  open the awareness quiz in your browser
    ${C_PROMPT}certs${NC}                 list the broken-certificate test sites to visit
EOF
}

module_dispatch() {
    local cmd="$1"; shift
    case "$cmd" in
        certs)
            printf "Visit each in your browser and read the warning it triggers:\n"
            printf "  ${C_PROMPT}https://localhost:8443${NC}   expired certificate\n"
            printf "  ${C_PROMPT}https://localhost:8444${NC}   self-signed / untrusted certificate\n"
            printf "  ${C_PROMPT}https://localhost:8445${NC}   certificate for the wrong hostname\n"
            printf "${C_DIM}(These are meant to fail — that is the lesson. Click through to see the page.)${NC}\n" ;;
        *) return 1 ;;
    esac
}
